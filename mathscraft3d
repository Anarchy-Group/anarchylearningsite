*{margin:0;padding:0;box-sizing:border-box;font-family:Inter,sans-serif;scroll-behavior:smooth;}
body{background:#0d0d0d;color:#eee;overflow-x:hidden;transition:background .3s,color .3s;}
body.light{background:#f4f4f4;color:#111;}
a{text-decoration:none;color:inherit;}
header{position:fixed;top:0;width:100%;display:flex;justify-content:space-between;align-items:center;padding:15px 30px;background:rgba(20,20,20,0.55);backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,.08);z-index:3000;}
body.light header{background:rgba(255,255,255,.65);border-bottom:1px solid rgba(0,0,0,.1);}
header h1{color:#ff3860;font-size:22px;}
nav{display:flex;align-items:center;gap:18px;}
.nav-item{position:relative;cursor:pointer;}
.dropdown{position:absolute;top:36px;left:0;display:none;flex-direction:column;min-width:200px;border-radius:10px;background:rgba(20,20,20,0.95);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.08);box-shadow:0 12px 30px rgba(0,0,0,.4);z-index:4000;}
body.light .dropdown{background:white;border:1px solid rgba(0,0,0,.1);}
.dropdown a{padding:10px 14px;}
.dropdown a:hover{background:rgba(255,255,255,.08);color:#ff3860;}
.theme-btn{background:#ff3860;border:none;color:white;padding:6px 12px;border-radius:6px;cursor:pointer;font-weight:600;}
.hero{height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:40px;}
.hero h2{font-size:48px;margin-bottom:15px;}
.hero p{max-width:650px;opacity:.9;}
.hero-buttons{margin-top:20px;}
.btn{display:inline-block;padding:10px 18px;margin:10px;border-radius:6px;background:#ff3860;color:white;font-weight:bold;}
section{padding:100px 30px;max-width:1100px;margin:auto;}
section h2{color:#ff3860;margin-bottom:20px;}
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:25px;}
.card{background:#111;padding:25px;border-radius:12px;border:1px solid #222;transition:all .3s;cursor:pointer;}
body.light .card{background:white;border:1px solid #ccc;}
.card:hover{border-color:#ff3860;transform:translateY(-5px);}
footer{text-align:center;padding:40px;opacity:.7;}
.hamburger{display:none;flex-direction:column;cursor:pointer;}
.hamburger span{height:3px;width:24px;background:#ff3860;margin:4px 0;}
@media(max-width:800px){nav{display:none;position:absolute;top:60px;right:0;background:#111;flex-direction:column;padding:20px;border-radius:8px;}nav.active{display:flex;}body.light nav{background:white;}.hamburger{display:flex;}}
